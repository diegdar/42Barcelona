# --- Archivos de Compilación ---
# Nunca subas los archivos objeto (.o) ni archivos de biblioteca (.a)
*.o
*.a
*.so
*.out

# --- Ejecutables y Temporales ---
# Si compilas con un nombre específico, añádelo aquí (ej: a.out)
a.out
*.dSYM/

# --- Archivos de Sistema / IDEs ---
# Para que no se suban configuraciones de tu ordenador personal (Mac o PC)
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*.swn

# --- Archivos de Evaluación / Testeo ---
# Si creas tus propios tests o usas los de la comunidad (ej: libft-war-machine)
# asegúrate de que no se suban al repo oficial de 42.
user_test/
test.c
a.out

# --- Archivos temporales de Vim (importante en 42) ---
*.swp
*.swo
.*.swp
.*.swo

# --- Otros archivos de edición ---
*~
*.save